            var k = "/lodging/content/awards/management/api/v2/generateScript.json?htid=" + htid + "&widgetType=" + e + "&style=" + b + "&size=" + c + "&brand=" + g + "&langId=" + d + "&noFollow=" + i + "&widgetName=" + h;
