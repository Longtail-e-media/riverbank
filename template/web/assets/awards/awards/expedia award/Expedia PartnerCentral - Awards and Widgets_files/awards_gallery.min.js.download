                            scoreElement: "<span class='widgetScore' style='top:14px;left:50px;font-size:12px;color:#78c41f;text-align: center;'><strong style='line-height:33px;font-size:33px;'>{{data}}</strong><span style='position:absolute;top:35px;left:-28px;width:120px;color: #3c3c3c;'>verified Wotif guest reviews</span></span>",
                            linkElement: "<span class='widgetLink' style='top:84px;height:30px;line-height:15px;width:138px;margin:0 7px;font-size:11px;color:#0064bb;;'><span style='display:table-cell;vertical-align:middle;'><a class='hotelName mcard-ignore' title='{{data}}' style='color:#0064bb;text-decoration:underline;'>{{data}}</a></span></span>"
                        }
                    }
                }
            }
        }
    };
});

